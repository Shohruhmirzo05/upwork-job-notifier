# Copy to .env for LOCAL testing only (GitHub Actions uses Secrets/Variables instead).
# Load with:  set -a && source .env && set +a && python notifier.py

TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Optional proxy (Webshare free tier download link). Leave empty to go direct first.
WEBSHARE_URL=

# Your niche filters (comma-separated, case-insensitive; matched on title+desc+skills)
KEYWORDS=swiftui,ios,swift,flutter,mobile app,ai agent,openai,anthropic,claude,supabase
EXCLUDE_KEYWORDS=wordpress,php,data entry,virtual assistant

# How many 50-job pages of "most recent" to scan per run (2 = newest 100 jobs)
MAX_PAGES=2

# ---- Optional AI scoring: Claude rates each new job 1-10 vs your profile ----
# Leave ANTHROPIC_API_KEY empty to disable (keyword filtering still works).
ANTHROPIC_API_KEY=
MIN_SCORE=7
SCORE_MODEL=claude-haiku-4-5-20251001
# One-line description of you; Claude scores fit against this. Blank = built-in default.
PROFILE=Senior mobile + AI developer: SwiftUI, iOS, Swift, Flutter, AI agents (OpenAI/Claude), Supabase. Wants serious clients with real budgets. Avoids WordPress, PHP, data entry, VA work.
