# local secrets — never commit
.env

# dedup state — lives in GitHub Actions cache, not the repo (keeps history clean)
seen.json

# cached visitor token (runtime only)
.token.json

# python
__pycache__/
*.pyc

# on-demand proposal job store (runtime only, cached in Actions)
store.json

# manual proposal QA artifacts
proposal-qa-output/

# Cloudflare tracker build/runtime + local credentials
tracker/node_modules/
tracker/dist/
tracker/.wrangler/
.tracker-credentials
