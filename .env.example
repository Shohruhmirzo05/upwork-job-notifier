# Copy to .env for LOCAL testing only (GitHub Actions uses Secrets/Variables instead).
# Load with:  set -a && source .env && set +a && python notifier.py

TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Optional proxy (Webshare free tier download link). Leave empty to go direct first.
WEBSHARE_URL=

# Newest jobs fetched per search lane (filters.json search_queries)
JOBS_PER_QUERY=50

# Max notifications per run (safety cap against flooding; best-scored first)
MAX_NOTIFS=25

# Only used if filters.json has no search_queries (global newest-jobs fallback)
MAX_PAGES=2

# ------------------------------------------------------------------
# Filtering is controlled by filters.json (edit that file, not env).
# The two vars below are only a FALLBACK used if filters.json is missing.
# ------------------------------------------------------------------
KEYWORDS=swiftui,ios,swift,flutter,mobile app,ai agent,openai,anthropic,claude,supabase
EXCLUDE_KEYWORDS=wordpress,php,data entry,virtual assistant

# ---- Auto proposals (optional, free): Google Gemini writes a draft per job ----
# Get a free key at https://aistudio.google.com/apikey  (no credit card).
# Leave empty to disable. Fill profile.md so the proposals sound like you.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PROPOSAL_MIN_SCORE=30

# ---- Optional dead-man's-switch (healthchecks.io ping URL) ----
HEALTHCHECK_URL=
