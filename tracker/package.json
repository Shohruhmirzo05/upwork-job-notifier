{
  "name": "upwork-proposals-tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite build && wrangler dev",
    "deploy": "vite build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply upwork-proposals --local",
    "db:migrate:remote": "wrangler d1 migrations apply upwork-proposals --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "wrangler": "^4.85.0"
  }
}
