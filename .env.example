# Copy to .env for LOCAL testing only (GitHub Actions uses Secrets/Variables instead).
# Load with:  set -a && source .env && set +a && python notifier.py

TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Optional proxy (Webshare free tier download link). Leave empty to go direct first.
WEBSHARE_URL=

# How many 50-job pages of "most recent" to scan per run (2 = newest 100 jobs)
MAX_PAGES=2

# Max notifications per run (safety cap against flooding)
MAX_NOTIFS=20

# ------------------------------------------------------------------
# Filtering is controlled by filters.json (edit that file, not env).
# The two vars below are only a FALLBACK used if filters.json is missing.
# ------------------------------------------------------------------
KEYWORDS=swiftui,ios,swift,flutter,mobile app,ai agent,openai,anthropic,claude,supabase
EXCLUDE_KEYWORDS=wordpress,php,data entry,virtual assistant
